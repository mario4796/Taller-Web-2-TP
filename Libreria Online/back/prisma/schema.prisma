generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
}

model Administradores {
  usuario_id Int      @id
  Usuarios   Usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Compradores {
  usuario_id Int      @id
  Usuarios   Usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  LibrosDigitalesAdquiridos LibroDigitalAdquirido[]
}

model Libros {
  id                     Int                      @id @default(autoincrement())
  isbn                   String                   @unique @db.VarChar(20)
  nombre                 String                   @db.VarChar(255)
  autor                  String                   @db.VarChar(255)
  precio                 Decimal                  @db.Decimal(10, 2)
  stock                  Int?                     @default(0)
  estado                 String?                  @default("DISPONIBLE") @db.VarChar(50)
  archivoDigital         String?                  @db.VarChar(500)
  LibrosDigitalesAdquiridos LibroDigitalAdquirido[]
}

model LibroDigitalAdquirido {
  id          Int      @id @default(autoincrement())
  comprador_id Int
  libro_id    Int
  fecha_adquisicion DateTime @default(now())
  Compradores Compradores @relation(fields: [comprador_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)
  Libros      Libros      @relation(fields: [libro_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([comprador_id, libro_id])
}

model Proveedores {
  usuario_id Int      @id
  Usuarios   Usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Usuarios {
  id              Int              @id @default(autoincrement())
  email           String           @unique @db.VarChar(255)
  contrasena      String           @db.VarChar(255)
  nombre          String           @db.VarChar(100)
  apellido        String           @db.VarChar(100)
  direccion       String           @db.VarChar(255)
  tipo_usuario    String           @db.VarChar(50)
  Administradores Administradores?
  Compradores     Compradores?
  Proveedores     Proveedores?
}
