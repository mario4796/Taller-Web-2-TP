generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
}

model Administradores {
  usuario_id Int      @id
  Usuarios   Usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Compradores {
  usuario_id Int       @id
  Usuarios   Usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Carrito    Carritos?
}

model Libros {
  id      Int           @id @default(autoincrement())
  isbn    String        @unique @db.VarChar(20)
  nombre  String        @db.VarChar(255)
  autor   String        @db.VarChar(255)
  precio  Decimal       @db.Decimal(10, 2)
  stock   Int?          @default(0)
  estado  String?       @default("DISPONIBLE") @db.VarChar(50)
  sinopsis String?
  categoria   CategoriaLibro @default(GENERAL)
  ofertas OfertaLibro[] 
}

model Proveedores {
  usuario_id Int      @id
  Usuarios   Usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model TiposUsuario {
  id     Int    @id @default(autoincrement())
  nombre String @unique @db.VarChar(50)

  usuarios Usuarios[]
}

model ListaProveedor {
  id              Int      @id @default(autoincrement())
  usuario_id      Int      @unique // Relación 1 a 1 con Usuario
  es_proveedor    Boolean  @default(false)
  fecha_solicitud DateTime @default(now())

  Usuario Usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
}

model Usuarios {
  id         Int    @id @default(autoincrement())
  email      String @unique @db.VarChar(255)
  contrasena String @db.VarChar(255)
  nombre     String @db.VarChar(100)
  apellido   String @db.VarChar(100)
  direccion  String @db.VarChar(255)

  tipo_usuario_id Int

  TipoUsuario TiposUsuario @relation(fields: [tipo_usuario_id], references: [id])

  ListaProveedor  ListaProveedor?
  Administradores Administradores?
  Compradores     Compradores?
  Proveedores     Proveedores?
}
enum EstadoOferta {
  ESPERANDO_ADMIN       
  ESPERANDO_PROVEEDOR   
  ACEPTADA             
  RECHAZADA             
}

model OfertaLibro {
  id               Int          @id @default(autoincrement())
  isbn             String
  nombre           String       
  autor            String
  precioProveedor  Decimal      @db.Decimal(10, 2)
  cantidadProveedor  Int          
  cantidadAdmin      Int?
  estado           EstadoOferta @default(ESPERANDO_ADMIN)
  createdAt        DateTime     @default(now())

  sinopsis String?
  categoria   CategoriaLibro @default(GENERAL)
  
  //proveedorId      Int
  //Proveedor        Proveedores  @relation(fields: [proveedorId], references: [usuario_id])

  libroId          Int?
  Libro            Libros?      @relation(fields: [libroId], references: [id])
}

enum CategoriaLibro {
  FICCION
  FANTASIA
  TERROR
  HISTORIA
  INFANTIL
  GENERAL
}
